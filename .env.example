# App mode flags
# Local development defaults can stay true while building UI and flows.
EXPO_PUBLIC_LOCAL_DEV=true
EXPO_PUBLIC_DEV_FULL_MOCK=true

# World Mini App backend
# Local mock example: http://127.0.0.1:8787
# Production example: https://your-world-backend.example.com
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8787

# Firebase
# Replace these with your real Firebase project values when moving beyond fallback/local-only setup.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
