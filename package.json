{
  "name": "expo-app",
  "private": true,
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "bunx rork start -p 0eov1rj688wrtzwxjndo7 --tunnel",
    "start-web": "bunx rork start -p 0eov1rj688wrtzwxjndo7 --web --tunnel",
    "start-web-dev": "DEBUG=expo bunx rork start -p 0eov1rj688wrtzwxjndo7 --web --tunnel",
    "dev": "expo start --clear",
    "dev:web": "expo start --web --clear",
    "dev:tunnel": "expo start --tunnel --clear",
    "dev:web:tunnel": "expo start --web --tunnel --clear",
    "world:mock": "node scripts/mock-world-backend.mjs",
    "world:mock:health": "curl http://127.0.0.1:${WORLD_MOCK_PORT:-8787}/health",
    "vercel:env:ls": "vercel env ls",
    "vercel:env:pull": "vercel env pull .env.vercel",
    "deploy:preview": "vercel deploy -y",
    "deploy:prod": "vercel deploy --prod -y",
    "firebase:rules:check": "node -e \"JSON.parse(require('fs').readFileSync('database.rules.json','utf8')); console.log('database.rules.json OK')\"",
    "ios": "expo start --ios --clear",
    "simulator:open": "open -a Simulator",
    "simulator:list": "xcrun simctl list devices available",
    "mobile:test": "playwright test",
    "mobile:test:headed": "playwright test --headed",
    "mobile:test:update": "playwright test --update-snapshots",
    "lint": "expo lint",
    "web": "expo start --web --clear",
    "export": "expo export --platform web --no-minify",
    "doctor": "npx expo-doctor"
  },
  "dependencies": {
